# Copy to .env.local and fill in. Required for production/hosting.

# REQUIRED in production — sign session JWTs. Generate a random 32+ char value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Locally this can be omitted (a dev fallback is used); in production the app refuses to boot without it.
SESSION_SECRET=

# Optional — Ops Sheet Bridge (two-way Google Sheets sync). Leave blank to disable the feature;
# the rest of the app works without it and the /sync page will show a "not configured" notice.
# Point these at a Google OAuth *Desktop* client JSON and a token JSON holding a refresh_token
# with the https://www.googleapis.com/auth/spreadsheets scope.
GOOGLE_OAUTH_CLIENT_PATH=
GOOGLE_SHEETS_TOKEN_PATH=
SYNC_SPREADSHEET_ID=
